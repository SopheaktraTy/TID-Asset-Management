spring:
  application:
    name: asset-management-bridge

  datasource:
    url: jdbc:postgresql://localhost:5432/TID_Asset_Management_DB
    username: postgres
    password: Pheaktra123

  jpa:
    hibernate:
      ddl-auto: validate
    show-sql: true
    properties:
      hibernate:
        format_sql: true

  flyway:
    enabled: true
    baseline-on-migrate: true
    locations:
      - classpath:db/migration
      - classpath:db/seeder

  mail:
    host: smtp.office365.com
    port: 587
    username: sopheaktra.t@bakertilly.com.kh
    password: BTC@2026 
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true

springdoc:
  swagger-ui:
    path: /api               # Access path: http://localhost:8080/api
    operations-sorter: alpha # Sort endpoints alphabetically
    tags-sorter: alpha       # Sort tags (Asset, User, etc.) alphabetically
  api-docs:
    path: /api-docs          # Raw JSON documentation path

server:
  port: 8080

jwt:
  secret: hq3qG2Hj4M5vF7bN8kL9sP1hT4xD6rW8yB2cZ5eV9tI1oU3mK6nA8sJ0gR3yF7v # Replace with a strong, completely secure secret
